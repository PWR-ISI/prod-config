# ── LocalStack ────────────────────────────────────────────────────────────────
# Required to run LocalStack Pro (get a token at https://localstack.cloud)
LOCALSTACK_AUTH_TOKEN=

# ── Cognito ───────────────────────────────────────────────────────────────────
# Populated automatically by localstack-init/00-setup.sh on first run.
# Copy the printed values here and restart the service containers.
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# ── AWS (LocalStack uses dummy values; keep as-is for local dev) ──────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
